FROM python:3.11-slim
WORKDIR /app
RUN pip install flask psycopg2-binary
COPY app.py .

ARG BUILD_TIME
ARG BUILD_USER
ARG BUILD_HOST
ARG BUILD_OS
ARG BUILD_KERNEL
ARG BUILD_UUID

ENV BUILD_TIME=$BUILD_TIME BUILD_USER=$BUILD_USER BUILD_HOST=$BUILD_HOST \
    BUILD_OS=$BUILD_OS BUILD_KERNEL=$BUILD_KERNEL BUILD_UUID=$BUILD_UUID

EXPOSE 8080
CMD ["python", "app.py"]

